{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "includeFiles": "frontend/**",
      "excludeFiles": "{venv/**,ai-simplifier/**,.git/**,__pycache__/**,.vscode/**}"
    }
  }
}
